import datetime
import pandas as pd
from typing import List, Dict, Optional

class Employee:
    def __init__(self, employee_id: str, name: str, is_active: bool = True):
        self.employee_id = employee_id
        self.name = name
        self.is_active = is_active
        self.nominations = []
        self.completed_trainings = []
        self.certificates = []

    def nominate_for_training(self, training_id: str, batch_month: str):
        self.nominations.append({"training_id": training_id, "batch_month": batch_month})

    def complete_training(self, training_id: str, completion_date: str, certificate: Optional[Dict] = None):
        self.completed_trainings.append({"training_id": training_id, "completion_date": completion_date})
        if certificate:
            self.certificates.append(certificate)

    def deactivate_employee(self):
        self.is_active = False

class Training:
    def __init__(self, training_id: str, name: str, batches: List[Dict]):
        self.training_id = training_id
        self.name = name
        self.batches = batches

class SkillversePortal:
    def __init__(self):
        self.employees = {}
        self.trainings = {}
        self.waiting_queue = []

    def add_employee(self, employee: Employee):
        self.employees[employee.employee_id] = employee

    def add_training(self, training: Training):
        self.trainings[training.training_id] = training

    def sync_attendance_records(self, hr_suite_data: pd.DataFrame):
        for _, row in hr_suite_data.iterrows():
            employee_id = row["employee_id"]
            training_id = row["training_id"]
            completion_date = row["completion_date"]
            if employee_id in self.employees:
                self.employees[employee_id].complete_training(training_id, completion_date)

    def revoke_nominations_for_exited_employees(self):
        for employee_id, employee in list(self.employees.items()):
            if not employee.is_active:
                for nomination in employee.nominations:
                    self.release_seat(nomination["training_id"], nomination["batch_month"])
                del self.employees[employee_id]

    def release_seat(self, training_id: str, batch_month: str):
        if training_id in self.trainings:
            for batch in self.trainings[training_id].batches:
                if batch["month"] == batch_month:
                    batch["available_seats"] += 1
                    self.notify_waiting_queue(training_id, batch_month)

    def notify_waiting_queue(self, training_id: str, batch_month: str):
        for employee_id in self.waiting_queue:
            if employee_id in self.employees:
                self.employees[employee_id].nominate_for_training(training_id, batch_month)
                self.waiting_queue.remove(employee_id)
                break

    def conduct_quarterly_survey(self, survey_data: pd.DataFrame):
        recommended_courses = survey_data["course_name"].value_counts().head(10)
        print("Top recommended courses:", recommended_courses)

    def upload_certificate(self, employee_id: str, certificate: Dict):
        if employee_id in self.employees:
            self.employees[employee_id].certificates.append(certificate)

    def check_certificate_expiry(self):
        today = datetime.date.today()
        for employee in self.employees.values():
            for certificate in employee.certificates:
                expiry_date = datetime.datetime.strptime(certificate["expiry_date"], "%Y-%m-%d").date()
                if (expiry_date - today).days <= 30:
                    print(f"Notification: Certificate {certificate['name']} for {employee.name} is expiring soon.")

    def notify_next_level_certification(self, employee_id: str, current_level: str):
        if employee_id in self.employees:
            next_level = self.get_next_level_certification(current_level)
            if next_level:
                print(f"Notification: Next level certification available for {self.employees[employee_id].name}: {next_level}")

    def get_next_level_certification(self, current_level: str) -> Optional[str]:
        certification_pathways = {
            "Entry": "Intermediate",
            "Intermediate": "Advanced",
            "Advanced": None
        }
        return certification_pathways.get(current_level)

# Example usage
if __name__ == "__main__":
    # Initialize Skillverse Portal
    skillverse = SkillversePortal()

    # Add employees
    employee_s = Employee("S", "Employee S")
    skillverse.add_employee(employee_s)

    # Add training
    training_xyz = Training("XYZ", "XYZ Training", [
        {"month": "September", "available_seats": 10},
        {"month": "October", "available_seats": 0},
        {"month": "November", "available_seats": 5}
    ])
    skillverse.add_training(training_xyz)

    # Employee S nominates for training
    employee_s.nominate_for_training("XYZ", "October")
    employee_s.nominate_for_training("XYZ", "November")

    # Simulate HR Suite data
    hr_suite_data = pd.DataFrame([
        {"employee_id": "S", "training_id": "XYZ", "completion_date": "2023-09-15"}
    ])

    # Sync attendance records
    skillverse.sync_attendance_records(hr_suite_data)

    # Conduct quarterly survey
    survey_data = pd.DataFrame([
        {"employee_id": "S", "course_name": "Advanced Python"},
        {"employee_id": "S", "course_name": "Data Science"},
        {"employee_id": "T", "course_name": "Advanced Python"},
        {"employee_id": "U", "course_name": "Machine Learning"}
    ])
    skillverse.conduct_quarterly_survey(survey_data)

    # Upload certificate
    skillverse.upload_certificate("S", {
        "name": "XYZ Training",
        "expiry_date": "2024-09-15"
    })

    # Check certificate expiry
    skillverse.check_certificate_expiry()

    # Notify next level certification
    skillverse.notify_next_level_certification("S", "Entry")
